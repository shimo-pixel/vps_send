# ---------- 与仓库 docker-compose.yml 一起用时 ----------
# compose 里已为 API 容器写死 MINIO_ENDPOINT=minio:9000，下面 MinIO 账号需与 MINIO_ROOT_* 一致。
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=uploads
FLASK_PORT=5000
MINIO_PUBLISH_PORT=9000
MINIO_CONSOLE_PORT=9001

# 下面两行若留在 .env，会被 compose 的 environment 覆盖；本地直接 python app.py 时请改成可连的地址：
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY 与 MinIO 控制台一致

# ---------- Flask 本机运行、MinIO 在宿主机 9000 时 ----------
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_SECURE=false
# MINIO_BUCKET=uploads
# FLASK_PORT=5000

# ---------- 仅 API 在 Docker、MinIO 在宿主机 9000 时（Linux）----------
# 不要用 127.0.0.1。在 compose 的 minio-flask-api 下增加：
#   extra_hosts:
#     - "host.docker.internal:host-gateway"
# 且 MINIO_ENDPOINT=host.docker.internal:9000
